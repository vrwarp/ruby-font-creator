{
  "name": "hanzi-pinyin-font",
  "version": "2.0.0",
  "description": "Project to create a Chinese font displaying Hanzi (汉字) characters followed by transliteration/pronunciation (Pīnyīn)",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "author": [
    "Édouard Lopez",
    "Hugo Lopez"
  ],
  "scripts": {
    "build:font": "NODE_OPTIONS=\"--max-old-space-size=8192\" tsx ./index.ts",
    "build:gsub": "python3 scripts/inject-gsub.py build/ruby-font-creator.ttf build/polyphonic-map.json",
    "build": "tsc",
    "build:web": "vite build frontend",
    "dev": "vite frontend",
    "generate-data": "tsx data/chinese/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "download:vendor": "node scripts/download-vendor.js",
    "download:pyodide": "node scripts/download-pyodide.js",
    "download:onnx": "node scripts/download-onnx.js",
    "download:opencc": "node scripts/download-opencc.js",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@jax-js/jax": "^0.1.11",
    "@jax-js/optax": "^0.1.2",
    "onnxruntime-web": "^1.26.0",
    "opentype.js": "^1.3.4",
    "svg2ttf": "^6.1.0",
    "svgpath": "^2.6.0",
    "svgtofont": "^3.21.6",
    "text-to-svg": "^3.1.5",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/jsdom": "^21.1.7",
    "@types/opentype.js": "^1.3.10",
    "@types/yargs": "^17.0.33",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
